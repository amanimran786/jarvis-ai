#!/usr/bin/env bash
# Jarvis CLI wrapper — Multica-compatible agent entrypoint.
#
# Multica daemon invokes this as:   jarvis -p "<task>"
# Direct usage:                     jarvis <message>
#                                   jarvis --status
#                                   jarvis --memory
#
# The script forwards all arguments to jarvis_cli.py, resolved relative to
# this file so it works regardless of working directory.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$SCRIPT_DIR/jarvis_cli.py" "$@"
