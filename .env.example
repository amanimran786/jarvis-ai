# Local-first default runtime
JARVIS_API_HOST=127.0.0.1
JARVIS_API_PORT=8765
JARVIS_REQUEST_STARTUP_PERMISSIONS=0
JARVIS_REQUEST_STARTUP_ADMIN=0

# Optional: set a fixed API token for LAN or remote clients.
# If omitted, Jarvis generates an ephemeral token at startup and stores it in
# local runtime metadata for trusted local tools like jarvis_cli.py.
JARVIS_API_TOKEN=

# Local model defaults
LOCAL_DEFAULT_MODEL=gemma4:e4b
LOCAL_CODER_MODEL=qwen2.5-coder:7b
LOCAL_REASONING_MODEL=deepseek-r1:14b

# Optional cloud fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
